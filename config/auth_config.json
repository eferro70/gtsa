{
  "fixed_headers": [
    { "name": "x-chave-acesso-sistema", "env_var": "CHAVE_ACESSO_SISTEMA" }
  ],
  "role_tokens": {
    "ADMINISTRADOR": { "env_var": "TOKEN_ADMIN_PRIMEIRO" },
    "GESTOR": { "env_var": "TOKEN_GESTOR1" },
    "REQUISITANTE": { "env_var": "TOKEN_REQUISITANTE1" },
    "INTERESSADO": { "env_var": "TOKEN_INTERESSADO1" }
  },
  "default_role": "ADMINISTRADOR",
  "auth_header": "Authorization",
  "auth_prefix": "Bearer "
}
